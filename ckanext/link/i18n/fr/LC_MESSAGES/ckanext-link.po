msgid "Link Checker"
msgstr "Vérificateur de liens"

msgid "Total Checked"
msgstr "Total vérifié"

msgid "Broken"
msgstr "Brisés"

msgid "OK"
msgstr "OK"

msgid "Last Checked"
msgstr "Dernière vérification"

msgid "Never"
msgstr "Jamais"

msgid "Job queued"
msgstr "Tâche en file d'attente"

msgid "Waiting for worker..."
msgstr "En attente d'un worker..."

msgid "Checking links..."
msgstr "Vérification des liens..."

msgid "broken"
msgstr "brisés"

msgid "Link Check Running..."
msgstr "Vérification en cours..."

msgid "Run Link Check"
msgstr "Lancer la vérification des liens"

msgid "Show All"
msgstr "Afficher tout"

msgid "Broken Only"
msgstr "Brisés seulement"

msgid "Dataset"
msgstr "Jeu de données"

msgid "URL"
msgstr "URL"

msgid "Status"
msgstr "Statut"

msgid "Error"
msgstr "Erreur"

msgid "Checked"
msgstr "Vérifié"

msgid "N/A"
msgstr "N/D"

msgid "No link check results yet. Click \"Run Link Check\" to start."
msgstr "Aucun résultat de vérification. Cliquez sur « Lancer la vérification des liens » pour commencer."

msgid "Need to be system administrator to administer"
msgstr "Vous devez être administrateur système pour accéder à cette page"

msgid "A link check job is already running."
msgstr "Une tâche de vérification des liens est déjà en cours."

msgid "Link check job has been queued."
msgstr "La tâche de vérification des liens a été mise en file d'attente."

msgid "Worker stopped responding."
msgstr "Le worker ne répond plus."

msgid "The previous job appears to have crashed. Click Resume to continue where it left off."
msgstr "La tâche précédente semble avoir échoué. Cliquez sur Reprendre pour continuer là où elle s'est arrêtée."

msgid "Resume Link Check"
msgstr "Reprendre la vérification des liens"

msgid "Resuming link check from where it left off."
msgstr "Reprise de la vérification des liens là où elle s'était arrêtée."
